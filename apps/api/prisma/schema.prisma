model Allergy {
  id           String    @id @default(uuid())
  patientId    String    @map("patient_id")
  allergen     String
  allergenType String    @map("allergen_type")
  snomedCode   String?   @map("snomed_code")
  severity     String?
  reaction     String?
  status       String    @default("ACTIVE")
  onsetDate    DateTime? @map("onset_date")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  patient      Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("allergies")
}

// ============================================
// CLINICAL - IMMUNIZATIONS
// ============================================

model Immunization {
  id                String    @id @default(uuid())
  patientId         String    @map("patient_id")
  cvxCode           String?   @map("cvx_code")
  vaccineName       String    @map("vaccine_name")
  manufacturer      String?
  lotNumber         String?   @map("lot_number")
  doseNumber        Int?      @map("dose_number")
  seriesTotal       Int?      @map("series_total")
  administrationSite String?  @map("administration_site")
  route             String?
  administeredAt    DateTime  @map("administered_at")
  administeredById  String?   @map("administered_by_id")
  status            String    @default("COMPLETED")
  refusalReason     String?   @map("refusal_reason")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  patient           Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@map("immunizations")
}

// ============================================
// LABORATORY
// ============================================

model LabOrder {
  id              String    @id @default(uuid())
  patientId       String    @map("patient_id")
  providerId      String?   @map("provider_id")
  testCode        String?   @map("test_code")
  testName        String?   @map("test_name")
  status          String    @default("ORDERED")
  priority        String    @default("ROUTINE")
  clinicalInfo    String?   @map("clinical_info")
  fastingRequired Boolean   @default(false) @map("fasting_required")
  externalOrderId String?   @map("external_order_id")
  isAbnormal      Boolean   @default(false) @map("is_abnormal")
  results         Json?
  orderedAt       DateTime  @default(now()) @map("ordered_at")
  collectedAt     DateTime? @map("collected_at")
  resultedAt      DateTime? @map("resulted_at")
  reviewedById    String?   @map("reviewed_by_id")
  reviewedAt      DateTime? @map("reviewed_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  patient         Patient   @relation(fields: [patientId], references: [id])
  provider        User?     @relation(fields: [providerId], references: [id])
  items           LabOrderItem[]

  @@index([patientId])
  @@index([status])
  @@map("lab_orders")
}

model LabOrderItem {
  id             String  @id @default(uuid())
  labOrderId     String  @map("lab_order_id")
  loincCode      String? @map("loinc_code")
  testName       String  @map("test_name")
  result         String?
  resultValue    Decimal? @map("result_value") @db.Decimal(12, 4)
  unit           String?
  referenceRange String? @map("reference_range")
  flag           String?
  status         String  @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  labOrder       LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)

  @@map("lab_order_items")
}

// ============================================
// PROCEDURES
// ============================================

model Procedure {
  id             String    @id @default(uuid())
  patientId      String    @map("patient_id")
  encounterId    String?   @map("encounter_id")
  cptCode        String?   @map("cpt_code")
  icd10Codes     String?   @map("icd10_codes")
  name           String
  description    String?
  status         String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED, POSTPONED
  scheduledAt    DateTime? @map("scheduled_at")
  performedAt    DateTime? @map("performed_at")
  completedAt    DateTime? @map("completed_at")
  cancelledAt    DateTime? @map("cancelled_at")
  cancelReason   String?   @map("cancel_reason")
  performedById  String?   @map("performed_by_id")
  orderedById    String?   @map("ordered_by_id")
  assistantIds   String?   @map("assistant_ids") // JSON array of user IDs
  facility       String?
  location       String?   // Specific room/OR
  preOpNotes     String?   @map("pre_op_notes")
  postOpNotes    String?   @map("post_op_notes")
  operativeNotes String?   @map("operative_notes")
  complications  String?
  anesthesia     String?
  anesthesiaType String?   @map("anesthesia_type") // LOCAL, REGIONAL, GENERAL, SEDATION
  laterality     String?   // LEFT, RIGHT, BILATERAL
  specimenCollected Boolean @default(false) @map("specimen_collected")
  specimenNotes  String?   @map("specimen_notes")
  pathologyOrdered Boolean @default(false) @map("pathology_ordered")
  estimatedDuration Int?   @map("estimated_duration") // minutes
  actualDuration Int?      @map("actual_duration") // minutes
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  patient        Patient   @relation(fields: [patientId], references: [id])
  encounter      Encounter? @relation(fields: [encounterId], references: [id])
  performedBy    User?     @relation("ProcedurePerformer", fields: [performedById], references: [id])
  orderedBy      User?     @relation("ProcedureOrderer", fields: [orderedById], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([scheduledAt])
  @@map("procedures")
}

// ============================================
// DOCUMENTS
// ============================================

model ClinicalDocument {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  encounterId String?   @map("encounter_id")
  categoryId  String?   @map("category_id")
  title       String
  description String?
  documentType String?  @map("document_type") // LAB_RESULT, IMAGING, CONSULTATION, DISCHARGE_SUMMARY, REFERRAL, CONSENT, OTHER
  fileKey     String    @map("file_key")
  fileUrl     String?   @map("file_url")
  fileName    String?   @map("file_name")
  mimeType    String?   @map("mime_type")
  fileSize    Int?      @map("file_size")
  status      String    @default("ACTIVE") // DRAFT, PENDING_REVIEW, FINAL, SIGNED, AMENDED, OBSOLETE
  uploadedById String?  @map("uploaded_by_id")
  reviewedById String?  @map("reviewed_by_id")
  reviewedAt  DateTime? @map("reviewed_at")
  signedById  String?   @map("signed_by_id")
  signedAt    DateTime? @map("signed_at")
  // Versioning
  version     Int       @default(1)
  previousVersionId String? @map("previous_version_id")
  versionNote String?   @map("version_note")
  // Sharing
  sharedWithPatient Boolean @default(false) @map("shared_with_patient")
  sharedAt    DateTime? @map("shared_at")
  // Source tracking
  sourceFacility String? @map("source_facility")
  sourceProvider String? @map("source_provider")
  receivedAt  DateTime? @map("received_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  patient     Patient   @relation(fields: [patientId], references: [id])
  encounter   Encounter? @relation(fields: [encounterId], references: [id])
  category    DocumentCategory? @relation(fields: [categoryId], references: [id])
  uploadedBy  User?     @relation("DocumentUploader", fields: [uploadedById], references: [id])
  reviewedBy  User?     @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  signedBy    User?     @relation("DocumentSigner", fields: [signedById], references: [id])
  previousVersion ClinicalDocument? @relation("DocumentVersions", fields: [previousVersionId], references: [id])
  versions    ClinicalDocument[] @relation("DocumentVersions")

  @@index([patientId])
  @@index([status])
  @@index([documentType])
  @@map("clinical_documents")
}

model DocumentCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  description String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  documents ClinicalDocument[]

  @@map("document_categories")
}

// ============================================
// CARE PLANS
// ============================================

model CarePlan {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  title       String
  description String?
  planType    String?   @map("plan_type") // e.g., DIABETES, HYPERTENSION, POST_SURGICAL
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED, ON_HOLD
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  reviewDate  DateTime? @map("review_date")
  createdById String?   @map("created_by_id")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  patient     Patient   @relation(fields: [patientId], references: [id])
  createdBy   User?     @relation("CarePlanCreator", fields: [createdById], references: [id])
  goals       CarePlanGoal[]
  interventions CarePlanIntervention[]
  teamMembers CarePlanTeamMember[]

  @@index([patientId])
  @@index([status])
  @@map("care_plans")
}

model CarePlanGoal {
  id          String    @id @default(uuid())
  carePlanId  String    @map("care_plan_id")
  title       String
  description String?
  status      String    @default("IN_PROGRESS") // IN_PROGRESS, ACHIEVED, ABANDONED
  priority    String    @default("MEDIUM") // HIGH, MEDIUM, LOW
  targetDate  DateTime? @map("target_date")
  achievedAt  DateTime? @map("achieved_at")
  progressNotes String? @map("progress_notes")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  carePlan    CarePlan  @relation(fields: [carePlanId], references: [id], onDelete: Cascade)

  @@index([carePlanId])
  @@map("care_plan_goals")
}

model CarePlanIntervention {
  id          String    @id @default(uuid())
  carePlanId  String    @map("care_plan_id")
  title       String
  description String?
  interventionType String? @map("intervention_type") // MEDICATION, THERAPY, EDUCATION, MONITORING, PROCEDURE
  frequency   String?   // e.g., "Daily", "Weekly", "As needed"
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED, DISCONTINUED
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  assignedToId String?  @map("assigned_to_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  carePlan    CarePlan  @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  assignedTo  User?     @relation("InterventionAssignee", fields: [assignedToId], references: [id])

  @@index([carePlanId])
  @@map("care_plan_interventions")
}

model CarePlanTeamMember {
  id          String    @id @default(uuid())
  carePlanId  String    @map("care_plan_id")
  userId      String?   @map("user_id")
  name        String?   // For external providers
  role        String    // e.g., PCP, SPECIALIST, NURSE, THERAPIST, CAREGIVER
  responsibilities String?
  addedAt     DateTime  @default(now()) @map("added_at")

  carePlan    CarePlan  @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  user        User?     @relation("CarePlanTeam", fields: [userId], references: [id])

  @@index([carePlanId])
  @@map("care_plan_team_members")
}

// ============================================
// REFERRALS
// ============================================

model Referral {
  id               String    @id @default(uuid())
  patientId        String    @map("patient_id")
  referringProviderId String? @map("referring_provider_id")
  referredToName   String    @map("referred_to_name")
  referredToSpecialty String? @map("referred_to_specialty")
  referredToNpi    String?   @map("referred_to_npi")
  reason           String
  urgency          String    @default("ROUTINE")
  status           String    @default("PENDING")
  clinicalInfo     String?   @map("clinical_info")
  diagnosisCodes   String?   @map("diagnosis_codes")
  requestedServices String?  @map("requested_services")
  referredAt       DateTime  @default(now()) @map("referred_at")
  completedAt      DateTime? @map("completed_at")
  cancelledAt      DateTime? @map("cancelled_at")
  cancelReason     String?   @map("cancel_reason")
  expiresAt        DateTime? @map("expires_at")
  // Authorization tracking
  authRequired     Boolean   @default(false) @map("auth_required")
  authNumber       String?   @map("auth_number")
  authStatus       String?   @map("auth_status") // PENDING, APPROVED, DENIED, EXPIRED
  authRequestedAt  DateTime? @map("auth_requested_at")
  authDecidedAt    DateTime? @map("auth_decided_at")
  authDenialReason String?   @map("auth_denial_reason")
  authValidUntil   DateTime? @map("auth_valid_until")
  authVisitsAuthorized Int?  @map("auth_visits_authorized")
  authVisitsUsed   Int       @default(0) @map("auth_visits_used")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  patient          Patient   @relation(fields: [patientId], references: [id])
  referringProvider User?    @relation("ReferringProvider", fields: [referringProviderId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([authStatus])
  @@map("referrals")
}

// ============================================
// BILLING
// ============================================

model Charge {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  encounterId String?  @map("encounter_id")
  providerId  String?  @map("provider_id")
  cptCode     String   @map("cpt_code")
  description String
  modifiers   String?
  units       Int      @default(1)
  fee         Decimal  @db.Decimal(10, 2)
  status      String   @default("BILLED")
  serviceDate DateTime @map("service_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient     Patient    @relation(fields: [patientId], references: [id])
  encounter   Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@map("charges")
}

model Claim {
  id            String   @id @default(uuid())
  patientId     String   @map("patient_id")
  claimNumber   String   @unique @map("claim_number")
  payerName     String?  @map("payer_name")
  payerId       String?  @map("payer_id")
  status        String   @default("DRAFT")
  totalAmount   Decimal  @map("total_amount") @db.Decimal(10, 2)
  paidAmount    Decimal  @default(0) @map("paid_amount") @db.Decimal(10, 2)
  submittedAt   DateTime? @map("submitted_at")
  paidAt        DateTime? @map("paid_at")
  deniedReason  String?  @map("denied_reason")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  patient       Patient  @relation(fields: [patientId], references: [id])
  items         ClaimItem[]

  @@index([patientId])
  @@index([status])
  @@map("claims")
}

model ClaimItem {
  id          String  @id @default(uuid())
  claimId     String  @map("claim_id")
  chargeId    String? @map("charge_id")
  cptCode     String  @map("cpt_code")
  description String
  modifiers   String?
  units       Int     @default(1)
  fee         Decimal @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  claim       Claim   @relation(fields: [claimId], references: [id], onDelete: Cascade)
  charge      Charge? @relation(fields: [chargeId], references: [id])

  @@map("claim_items")
}

model Payment {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  claimId     String?  @map("claim_id")
  amount      Decimal  @db.Decimal(10, 2)
  method      String
  source      String   @default("PATIENT")
  reference   String?
  status      String   @default("COMPLETED")
  notes       String?
  postedById  String?  @map("posted_by_id")
  paidAt      DateTime @default(now()) @map("paid_at")
  createdAt   DateTime @default(now()) @map("created_at")

  patient     Patient  @relation(fields: [patientId], references: [id])
  postedBy    User?    @relation("PaymentPostedBy", fields: [postedById], references: [id])

  @@index([patientId])
  @@map("payments")
}

model FeeSchedule {
  id          String   @id @default(uuid())
  name        String
  facilityId  String?  @map("facility_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       FeeScheduleItem[]

  @@map("fee_schedules")
}

model FeeScheduleItem {
  id            String  @id @default(uuid())
  feeScheduleId String  @map("fee_schedule_id")
  cptCode       String  @map("cpt_code")
  description   String
  fee           Decimal @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  feeSchedule   FeeSchedule @relation(fields: [feeScheduleId], references: [id], onDelete: Cascade)

  @@unique([feeScheduleId, cptCode])
  @@map("fee_schedule_items")
}

// ============================================
// INSURANCE
// ============================================

model InsuranceCompany {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  state     String?
  zipCode   String?  @map("zip_code")
  phone     String?
  fax       String?
  email     String?
  payerId   String?  @map("payer_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  plans     InsurancePlan[]

  @@map("insurance_companies")
}

model InsurancePlan {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  name            String
  planType        String?  @map("plan_type")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company         InsuranceCompany @relation(fields: [companyId], references: [id])
  patientInsurances PatientInsurance[]

  @@map("insurance_plans")
}

// ============================================
// MESSAGING
// ============================================

model MessageThread {
  id        String   @id @default(uuid())
  subject   String
  patientId String?  @map("patient_id")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patient     Patient?  @relation(fields: [patientId], references: [id])
  participants ThreadParticipant[]
  messages    Message[]

  @@map("message_threads")
}

model ThreadParticipant {
  id        String   @id @default(uuid())
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("thread_participants")
}

model Message {
  id        String    @id @default(uuid())
  threadId  String    @map("thread_id")
  senderId  String    @map("sender_id")
  body      String
  isRead    Boolean   @default(false) @map("is_read")
  priority  String    @default("NORMAL")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  thread    MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender    User      @relation("MessageSender", fields: [senderId], references: [id])

  @@index([threadId])
  @@map("messages")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String
  data      Json?
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================
// AUDIT & COMPLIANCE
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  isBreakGlass Boolean  @default(false) @map("is_break_glass")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// TERMINOLOGY / CODE SETS
// ============================================

model CodeSet {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  version     String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  codes       CodeValue[]

  @@map("code_sets")
}

model CodeValue {
  id          String  @id @default(uuid())
  codeSetId   String  @map("code_set_id")
  code        String
  name        String
  description String?
  parentCode  String? @map("parent_code")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  codeSet     CodeSet @relation(fields: [codeSetId], references: [id], onDelete: Cascade)

  @@unique([codeSetId, code])
  @@index([code])
  @@map("code_values")
}

// ============================================
// TELEHEALTH
// ============================================

model TelehealthSession {
  id            String    @id @default(uuid())
  appointmentId String?   @map("appointment_id")
  patientId     String    @map("patient_id")
  providerId    String    @map("provider_id")
  roomCode      String    @unique @map("room_code")
  sessionToken  String?   @map("session_token")
  status        String    @default("SCHEDULED")
  scheduledAt   DateTime  @default(now()) @map("scheduled_at")
  startedAt     DateTime? @map("started_at")
  endedAt       DateTime? @map("ended_at")
  maxDuration   Int       @default(60) @map("max_duration")
  duration      Int?
  settings      Json?
  participants  Json?
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  patient       Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@map("telehealth_sessions")
}

// ============================================
// SYSTEM
// ============================================

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Task {
  id           String    @id @default(uuid())
  title        String
  description  String?
  status       String    @default("PENDING")
  priority     String    @default("NORMAL")
  assignedToId String?   @map("assigned_to_id")
  dueDate      DateTime? @map("due_date")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([assignedToId])
  @@map("tasks")
}

// CareForge - Healthcare Platform Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// IDENTITY & ACCESS MANAGEMENT
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  middleName    String?   @map("middle_name")
  prefix        String?
  suffix        String?
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret")
  lastLoginAt   DateTime? @map("last_login_at")
  lastLoginIp   String?   @map("last_login_ip")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  roles         UserRole[]
  facilities    UserFacility[]
  auditLogs     AuditLog[]
  sentMessages  Message[]      @relation("MessageSender")
  notifications Notification[]
  encounters    Encounter[]    @relation("EncounterProvider")
  appointments  Appointment[]  @relation("AppointmentProvider")
  labOrders     LabOrder[]
  prescriptions Prescription[]
  medications   Medication[]
  postedPayments Payment[]    @relation("PaymentPostedBy")
  patient       Patient?
  // Scheduling relations
  providerSchedules ProviderSchedule[]
  scheduleExceptions ScheduleException[]
  waitlistEntries WaitlistEntry[]
  // Clinical note relations
  authoredNotes ClinicalNote[] @relation("NoteAuthor")
  attestedNotes ClinicalNote[] @relation("NoteAttester")
  // Referral relations
  referrals     Referral[]     @relation("ReferringProvider")
  // Care plan relations
  createdCarePlans CarePlan[]  @relation("CarePlanCreator")
  assignedInterventions CarePlanIntervention[] @relation("InterventionAssignee")
  carePlanTeams CarePlanTeamMember[] @relation("CarePlanTeam")
  // Procedure relations
  performedProcedures Procedure[] @relation("ProcedurePerformer")
  orderedProcedures Procedure[] @relation("ProcedureOrderer")
  // Document relations
  uploadedDocuments ClinicalDocument[] @relation("DocumentUploader")
  reviewedDocuments ClinicalDocument[] @relation("DocumentReviewer")
  signedDocuments ClinicalDocument[] @relation("DocumentSigner")
  // Insurance relations
  verifiedInsurances PatientInsurance[] @relation("InsuranceVerifier")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  isSystem    Boolean    @default(false) @map("is_system")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  description String?
  module      String
  createdAt   DateTime   @default(now()) @map("created_at")

  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid())
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Facility {
  id          String    @id @default(uuid())
  name        String
  code        String    @unique
  address     String?
  city        String?
  state       String?
  zipCode     String?   @map("zip_code")
  country     String?   @default("US")
  phone       String?
  fax         String?
  email       String?
  taxId       String?   @map("tax_id")
  npi         String?
  cliaNumber  String?   @map("clia_number")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users       UserFacility[]
  patients    Patient[]
  appointments Appointment[]
  encounters  Encounter[]
  // Scheduling relations
  providerSchedules ProviderSchedule[]
  scheduleResources ScheduleResource[]
  scheduleExceptions ScheduleException[]
  waitlistEntries WaitlistEntry[]

  @@map("facilities")
}

model UserFacility {
  id         String @id @default(uuid())
  userId     String @map("user_id")
  facilityId String @map("facility_id")
  isPrimary  Boolean @default(false) @map("is_primary")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([userId, facilityId])
  @@map("user_facilities")
}

// ============================================
// PATIENT MANAGEMENT
// ============================================

model Patient {
  id                  String    @id @default(uuid())
  userId              String?   @unique @map("user_id")
  medicalRecordNumber String?   @unique @map("medical_record_number")
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  middleName          String?   @map("middle_name")
  prefix              String?
  suffix              String?
  dateOfBirth         DateTime  @map("date_of_birth")
  gender              String
  ssn                 String?
  email               String?
  phone               String?
  mobilePhone         String?   @map("mobile_phone")
  address             String?
  city                String?
  state               String?
  zipCode             String?   @map("zip_code")
  country             String?   @default("US")
  preferredLanguage   String?   @map("preferred_language")
  maritalStatus       String?   @map("marital_status")
  employmentStatus    String?   @map("employment_status")
  race                String?
  ethnicity           String?
  status              String    @default("ACTIVE")
  photoUrl            String?   @map("photo_url")
  primaryProviderId   String?   @map("primary_provider_id")
  facilityId          String?   @map("facility_id")
  notes               String?
  // Guarantor information (responsible party for billing)
  guarantorFirstName  String?   @map("guarantor_first_name")
  guarantorLastName   String?   @map("guarantor_last_name")
  guarantorRelationship String? @map("guarantor_relationship")
  guarantorPhone      String?   @map("guarantor_phone")
  guarantorEmail      String?   @map("guarantor_email")
  guarantorAddress    String?   @map("guarantor_address")
  guarantorCity       String?   @map("guarantor_city")
  guarantorState      String?   @map("guarantor_state")
  guarantorZipCode    String?   @map("guarantor_zip_code")
  guarantorEmployer   String?   @map("guarantor_employer")
  // Registration metadata
  registeredById      String?   @map("registered_by_id")
  registeredAt        DateTime  @default(now()) @map("registered_at")
  registrationFacilityId String? @map("registration_facility_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  user                User?     @relation(fields: [userId], references: [id])
  facility            Facility? @relation(fields: [facilityId], references: [id])
  contacts            PatientContact[]
  consents            PatientConsent[]
  insurances          PatientInsurance[]
  encounters          Encounter[]
  appointments        Appointment[]
  vitalSigns          VitalSign[]
  conditions          Condition[]
  medications         Medication[]
  prescriptions       Prescription[]
  allergies           Allergy[]
  immunizations       Immunization[]
  labOrders           LabOrder[]
  procedures          Procedure[]
  documents           ClinicalDocument[]
  carePlans           CarePlan[]
  referrals           Referral[]
  charges             Charge[]
  claims              Claim[]
  payments            Payment[]
  messageThreads      MessageThread[]
  telehealthSessions  TelehealthSession[]
  waitlistEntries     WaitlistEntry[]

  @@index([lastName, firstName])
  @@index([dateOfBirth])
  @@index([status])
  @@map("patients")
}

model PatientContact {
  id            String   @id @default(uuid())
  patientId     String   @map("patient_id")
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  relationship  String?
  phone         String?
  email         String?
  address       String?
  isEmergency   Boolean  @default(false) @map("is_emergency")
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_contacts")
}

model PatientConsent {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  type        String
  status      String    @default("PENDING")
  signedAt    DateTime? @map("signed_at")
  expiresAt   DateTime? @map("expires_at")
  documentUrl String?   @map("document_url")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  patient     Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_consents")
}

model PatientInsurance {
  id              String   @id @default(uuid())
  patientId       String   @map("patient_id")
  insurancePlanId String?  @map("insurance_plan_id")
  companyName     String   @map("company_name")
  planName        String?  @map("plan_name")
  policyNumber    String   @map("policy_number")
  groupNumber     String?  @map("group_number")
  subscriberName  String?  @map("subscriber_name")
  subscriberDob   DateTime? @map("subscriber_dob")
  relationship    String?
  priority        Int      @default(1)
  isActive        Boolean  @default(true) @map("is_active")
  effectiveDate   DateTime? @map("effective_date")
  terminationDate DateTime? @map("termination_date")
  // Eligibility tracking
  eligibilityStatus String? @map("eligibility_status") // UNKNOWN, VERIFIED, INELIGIBLE, PENDING
  eligibilityVerifiedAt DateTime? @map("eligibility_verified_at")
  eligibilityVerifiedById String? @map("eligibility_verified_by_id")
  eligibilityNotes String? @map("eligibility_notes")
  // Cost sharing
  copayAmount     Decimal? @db.Decimal(10, 2) @map("copay_amount")
  coinsurancePercent Decimal? @db.Decimal(5, 2) @map("coinsurance_percent")
  deductibleAmount Decimal? @db.Decimal(10, 2) @map("deductible_amount")
  deductibleMet   Decimal? @db.Decimal(10, 2) @map("deductible_met")
  outOfPocketMax  Decimal? @db.Decimal(10, 2) @map("out_of_pocket_max")
  outOfPocketMet  Decimal? @db.Decimal(10, 2) @map("out_of_pocket_met")
  // Authorization
  authRequired    Boolean  @default(false) @map("auth_required")
  authPhoneNumber String?  @map("auth_phone_number")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  insurancePlan   InsurancePlan? @relation(fields: [insurancePlanId], references: [id])
  verifiedBy      User?    @relation("InsuranceVerifier", fields: [eligibilityVerifiedById], references: [id])

  @@index([patientId])
  @@map("patient_insurances")
}

// ============================================
// SCHEDULING
// ============================================

model Appointment {
  id          String    @id @default(uuid())
  patientId   String    @map("patient_id")
  providerId  String    @map("provider_id")
  facilityId  String?   @map("facility_id")
  appointmentTypeId String? @map("appointment_type_id")
  resourceId  String?   @map("resource_id")
  type        String    @default("OFFICE_VISIT")
  status      String    @default("SCHEDULED") // SCHEDULED, CONFIRMED, ARRIVED, ROOMED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  startTime   DateTime  @map("start_time")
  endTime     DateTime  @map("end_time")
  duration    Int       @default(30)
  reason      String?
  notes       String?
  isRecurring Boolean   @default(false) @map("is_recurring")
  recurringId String?   @map("recurring_id")
  roomId      String?   @map("room_id")
  // Patient flow tracking
  confirmedAt DateTime? @map("confirmed_at")
  checkedInAt DateTime? @map("checked_in_at")
  roomedAt    DateTime? @map("roomed_at")
  providerSeenAt DateTime? @map("provider_seen_at")
  checkedOutAt DateTime? @map("checked_out_at")
  completedAt DateTime? @map("completed_at")
  cancelledAt DateTime? @map("cancelled_at")
  cancelReason String?  @map("cancel_reason")
  noShowRecordedAt DateTime? @map("no_show_recorded_at")
  // Assignment
  scheduledById String? @map("scheduled_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  patient     Patient   @relation(fields: [patientId], references: [id])
  provider    User      @relation("AppointmentProvider", fields: [providerId], references: [id])
  facility    Facility? @relation(fields: [facilityId], references: [id])
  appointmentType AppointmentType? @relation(fields: [appointmentTypeId], references: [id])
  resource    ScheduleResource? @relation(fields: [resourceId], references: [id])
  encounter   Encounter?

  @@index([providerId, startTime])
  @@index([patientId])
  @@index([status])
  @@index([facilityId, startTime])
  @@map("appointments")
}

model ProviderSchedule {
  id          String   @id @default(uuid())
  providerId  String   @map("provider_id")
  facilityId  String?  @map("facility_id")
  dayOfWeek   Int      @map("day_of_week") // 0=Sunday, 6=Saturday
  startTime   String   @map("start_time")  // "08:00"
  endTime     String   @map("end_time")    // "17:00"
  slotDuration Int     @default(30) @map("slot_duration")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  provider    User     @relation(fields: [providerId], references: [id])
  facility    Facility? @relation(fields: [facilityId], references: [id])

  @@unique([providerId, facilityId, dayOfWeek])
  @@map("provider_schedules")
}

model AppointmentType {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  defaultDuration Int  @default(30) @map("default_duration")
  color       String   @default("#3B82F6")
  requiresProvider Boolean @default(true) @map("requires_provider")
  requiresRoom Boolean @default(false) @map("requires_room")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("appointment_types")
}

model ScheduleResource {
  id          String   @id @default(uuid())
  facilityId  String   @map("facility_id")
  name        String
  type        String   // ROOM, EQUIPMENT, etc.
  capacity    Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  facility    Facility @relation(fields: [facilityId], references: [id])
  appointments Appointment[]

  @@map("schedule_resources")
}

model ScheduleException {
  id          String   @id @default(uuid())
  providerId  String?  @map("provider_id")
  facilityId  String?  @map("facility_id")
  resourceId  String?  @map("resource_id")
  date        DateTime
  startTime   String?  @map("start_time") // null = all day
  endTime     String?  @map("end_time")
  reason      String?
  type        String   @default("TIME_OFF") // TIME_OFF, HOLIDAY, MAINTENANCE
  createdAt   DateTime @default(now()) @map("created_at")

  provider    User?    @relation(fields: [providerId], references: [id])
  facility    Facility? @relation(fields: [facilityId], references: [id])

  @@map("schedule_exceptions")
}

model WaitlistEntry {
  id          String   @id @default(uuid())
  patientId   String   @map("patient_id")
  providerId  String?  @map("provider_id")
  facilityId  String?  @map("facility_id")
  appointmentTypeId String? @map("appointment_type_id")
  reason      String?
  priority    Int      @default(0)
  preferredDays String? @map("preferred_days") // JSON array of day numbers
  preferredTimeOfDay String? @map("preferred_time_of_day") // MORNING, AFTERNOON, ANY
  status      String   @default("WAITING") // WAITING, SCHEDULED, EXPIRED, CANCELLED
  addedById   String?  @map("added_by_id")
  scheduledAppointmentId String? @map("scheduled_appointment_id")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  patient     Patient  @relation(fields: [patientId], references: [id])
  provider    User?    @relation(fields: [providerId], references: [id])
  facility    Facility? @relation(fields: [facilityId], references: [id])
  appointmentType AppointmentType? @relation(fields: [appointmentTypeId], references: [id])

  @@map("waitlist_entries")
}

// ============================================
// CLINICAL - ENCOUNTERS
// ============================================

model Encounter {
  id              String    @id @default(uuid())
  patientId       String    @map("patient_id")
  providerId      String    @map("provider_id")
  facilityId      String?   @map("facility_id")
  appointmentId   String?   @unique @map("appointment_id")
  type            String    @default("OFFICE_VISIT") // OFFICE_VISIT, TELEHEALTH, PROCEDURE, HOSPITAL, EMERGENCY, HOME
  status          String    @default("IN_PROGRESS") // DRAFT, IN_PROGRESS, PENDING_REVIEW, SIGNED, AMENDED, ENTERED_IN_ERROR
  chiefComplaint  String?   @map("chief_complaint")
  hpi             String?   // History of Present Illness
  ros             String?   // Review of Systems
  physicalExam    String?   @map("physical_exam")
  assessment      String?
  plan            String?
  instructions    String?
  // Lifecycle tracking
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  signedAt        DateTime? @map("signed_at")
  signedById      String?   @map("signed_by_id")
  cosignedById    String?   @map("cosigned_by_id")
  cosignedAt      DateTime? @map("cosigned_at")
  amendedAt       DateTime? @map("amended_at")
  amendedById     String?   @map("amended_by_id")
  amendmentReason String?   @map("amendment_reason")
  enteredInErrorAt DateTime? @map("entered_in_error_at")
  enteredInErrorById String? @map("entered_in_error_by_id")
  enteredInErrorReason String? @map("entered_in_error_reason")
  // Metadata
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  patient         Patient   @relation(fields: [patientId], references: [id])
  provider        User      @relation("EncounterProvider", fields: [providerId], references: [id])
  facility        Facility? @relation(fields: [facilityId], references: [id])
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])
  diagnoses       EncounterDiagnosis[]
  procedures      EncounterProcedure[]
  vitalSigns      VitalSign[]
  charges         Charge[]
  clinicalNotes   ClinicalNote[]
  procedureRecords Procedure[]
  documents       ClinicalDocument[]

  @@index([patientId])
  @@index([providerId])
  @@index([status])
  @@map("encounters")
}

model ClinicalNote {
  id              String    @id @default(uuid())
  encounterId     String    @map("encounter_id")
  authorId        String    @map("author_id")
  noteType        String    @map("note_type") // PROGRESS, CONSULTATION, PROCEDURE, DISCHARGE, etc.
  title           String?
  content         String
  status          String    @default("DRAFT") // DRAFT, FINAL, AMENDED, ENTERED_IN_ERROR
  // Attestation
  attestedAt      DateTime? @map("attested_at")
  attestedById    String?   @map("attested_by_id")
  // Amendment tracking (non-destructive)
  isAmendment     Boolean   @default(false) @map("is_amendment")
  amendsNoteId    String?   @map("amends_note_id")
  amendmentReason String?   @map("amendment_reason")
  // Metadata
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  encounter       Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  author          User      @relation("NoteAuthor", fields: [authorId], references: [id])
  attestedBy      User?     @relation("NoteAttester", fields: [attestedById], references: [id])
  amendsNote      ClinicalNote? @relation("NoteAmendments", fields: [amendsNoteId], references: [id])
  amendments      ClinicalNote[] @relation("NoteAmendments")

  @@index([encounterId])
  @@index([authorId])
  @@map("clinical_notes")
}

model EncounterDiagnosis {
  id          String  @id @default(uuid())
  encounterId String  @map("encounter_id")
  icd10Code   String  @map("icd10_code")
  description String
  isPrimary   Boolean @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")

  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("encounter_diagnoses")
}

model EncounterProcedure {
  id          String  @id @default(uuid())
  encounterId String  @map("encounter_id")
  cptCode     String  @map("cpt_code")
  description String
  modifiers   String?
  units       Int     @default(1)
  fee         Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@map("encounter_procedures")
}

// ============================================
// CLINICAL - VITALS
// ============================================

model VitalSign {
  id                String    @id @default(uuid())
  patientId         String    @map("patient_id")
  encounterId       String?   @map("encounter_id")
  systolic          Int?
  diastolic         Int?
  heartRate         Int?      @map("heart_rate")
  temperature       Decimal?  @db.Decimal(5, 2)
  tempUnit          String?   @default("F") @map("temp_unit")
  respiratoryRate   Int?      @map("respiratory_rate")
  oxygenSat         Decimal?  @map("oxygen_sat") @db.Decimal(5, 2)
  height            Decimal?  @db.Decimal(6, 2)
  weight            Decimal?  @db.Decimal(6, 2)
  bmi               Decimal?  @db.Decimal(5, 2)
  headCircumference Decimal?  @map("head_circumference") @db.Decimal(6, 2)
  waistCircumference Decimal? @map("waist_circumference") @db.Decimal(6, 2)
  painScale         Int?      @map("pain_scale")
  notes             String?
  recordedById      String?   @map("recorded_by_id")
  recordedAt        DateTime  @default(now()) @map("recorded_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  patient           Patient   @relation(fields: [patientId], references: [id])
  encounter         Encounter? @relation(fields: [encounterId], references: [id])

  @@index([patientId, recordedAt])
  @@map("vital_signs")
}

// ============================================
// CLINICAL - CONDITIONS
// ============================================

model Condition {
  id           String    @id @default(uuid())
  patientId    String    @map("patient_id")
  icd10Code    String?   @map("icd10_code")
  snomedCode   String?   @map("snomed_code")
  name         String
  description  String?
  status       String    @default("ACTIVE")
  severity     String?
  laterality   String?
  onsetDate    DateTime? @map("onset_date")
  resolvedDate DateTime? @map("resolved_date")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  patient      Patient   @relation(fields: [patientId], references: [id])

  @@index([patientId, status])
  @@map("conditions")
}

// ============================================
// CLINICAL - MEDICATIONS
// ============================================

model Medication {
  id              String    @id @default(uuid())
  patientId       String    @map("patient_id")
  rxnormCode      String?   @map("rxnorm_code")
  ndcCode         String?   @map("ndc_code")
  name            String
  dosage          String?
  frequency       String?
  route           String?
  duration        String?
  quantity        Int?
  refills         Int?
  status          String    @default("ACTIVE")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  discontinuedAt  DateTime? @map("discontinued_at")
  prescriberId    String?   @map("prescriber_id")
  pharmacyNcpdpId String?   @map("pharmacy_ncpdp_id")
  transmittedAt   DateTime? @map("transmitted_at")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  patient         Patient   @relation(fields: [patientId], references: [id])
  prescriber      User?     @relation(fields: [prescriberId], references: [id])

  @@index([patientId, status])
  @@map("medications")
}

model Prescription {
  id             String    @id @default(uuid())
  patientId      String    @map("patient_id")
  providerId     String    @map("provider_id")
  medicationName String    @map("medication_name")
  rxnormCode     String?   @map("rxnorm_code")
  ndcCode        String?   @map("ndc_code")
  dosage         String
  frequency      String
  route          String?
  duration       String?
  quantity       String?
  refills        Int       @default(0)
  refillsUsed    Int       @default(0) @map("refills_used")
  instructions   String?
  deaSchedule    String?   @map("dea_schedule")
  status         String    @default("ACTIVE")
  pharmacyName   String?   @map("pharmacy_name")
  pharmacyPhone  String?   @map("pharmacy_phone")
  prescribedAt   DateTime  @default(now()) @map("prescribed_at")
  expiresAt      DateTime? @map("expires_at")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  patient        Patient   @relation(fields: [patientId], references: [id])
  provider       User      @relation(fields: [providerId], references: [id])

  @@index([patientId])
  @@map("prescriptions")
}

// ============================================
// CLINICAL - ALLERGIES

# CareForge API Environment Configuration
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://careforge:careforge_dev_2024@localhost:5432/careforge?schema=public

# JWT
JWT_SECRET=careforge-super-secret-jwt-key-change-in-production-2024
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=careforge-refresh-secret-key-change-in-production-2024
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3 Storage
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=careforge_admin
S3_SECRET_KEY=careforge_storage_2024
S3_BUCKET=careforge-documents

# Email (MailHog for dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@careforge.health

# OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# App
APP_NAME=CareForge
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
